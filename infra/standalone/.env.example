VOYANT_ENV=local
VOYANT_DEBUG=false
VOYANT_SECRETS_BACKEND=env
VOYANT_SECRET_KEY=replace-with-strong-secret-key-min-50-chars
VOYANT_DEPLOYMENT_MODE=standalone
VOYANT_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_HOST=voyant_postgres
POSTGRES_USER=voyant
POSTGRES_PASSWORD=voyant
POSTGRES_DB=voyant
DATABASE_URL=postgresql://voyant:voyant@voyant_postgres:5432/voyant

REDIS_PASSWORD=voyant
REDIS_URL=redis://:voyant@voyant_redis:6379/0

KAFKA_BOOTSTRAP_SERVERS=voyant_kafka:9092
KAFKA_ADVERTISED_LISTENERS=EXTERNAL://voyant_kafka:9092,INTERNAL://voyant_kafka:29092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

TEMPORAL_HOST=voyant_temporal:7233
TEMPORAL_TASK_QUEUE=voyant-tasks
TEMPORAL_CORS_ORIGINS=http://localhost:45400

MINIO_ENDPOINT=voyant_minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_INTERNAL_URL=http://voyant_minio:9000

DATAHUB_GMS_URL=http://voyant-datahub-gms:8080
DATAHUB_DATABASE_URL=jdbc:postgresql://voyant-postgres:5432/datahub
DATAHUB_DATABASE_USERNAME=voyant
DATAHUB_DATABASE_PASSWORD=voyant
DATAHUB_SECRET=replace-datahub-secret

TRINO_URL=http://voyant_trino:8080
KEYCLOAK_URL=http://voyant_keycloak:8080
KEYCLOAK_REALM=voyant
KEYCLOAK_CLIENT_ID=voyant-api
KEYCLOAK_CLIENT_SECRET=replace-keycloak-client-secret

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_DB_URL=jdbc:postgresql://voyant-postgres:5432/keycloak
KC_DB_USERNAME=voyant
KC_DB_PASSWORD=voyant

LAGO_API_URL=http://voyant_lago_api:3000
LAGO_API_KEY=replace-lago-api-key
LAGO_SECRET_KEY=replace-lago-secret-key
LAGO_ENCRYPTION_KEY=replace-lago-encryption-key
LAGO_RSA_PRIVATE_KEY=replace-lago-rsa-private-key-base64
LAGO_DATABASE_URL=postgresql://voyant:voyant@voyant-postgres:5432/lago
LAGO_REDIS_URL=redis://:voyant@voyant_redis:6379/2

VOYANT_MCP_API_URL=http://voyant_api:8000/v1
VOYANT_MCP_API_TOKEN=

VOYANT_ENABLE_QUALITY=true
VOYANT_ENABLE_BILLING=true
VOYANT_ENABLE_DATAHUB=false
VOYANT_ENABLE_MFA=false

SERPER_API_KEY=
SERPER_SEARCH_URL=https://google.serper.dev/search
VOYANT_READY_ENDPOINT=http://voyant_api:8000/readyz
VOYANT_API_HEALTHCHECK_URL=http://localhost:8000/healthz
MINIO_HEALTHCHECK_URL=http://localhost:9000/minio/health/live
ELASTICSEARCH_HEALTHCHECK_URL=http://voyant_elasticsearch:9200/_cluster/health
KEYCLOAK_HEALTHCHECK_URL=http://voyant_keycloak:8080/health/ready
VOYANT_VERIFY_DISCOVERY_SPEC_URL=
VOYANT_VERIFY_METRICS_BASE_URL=http://voyant_api:8000

# Optional build-time transcription deps (CPU-only default recommended)
VOYANT_WITH_TRANSCRIBE=0
VOYANT_TORCH_DEVICE=cpu
PYTORCH_INDEX_URL_CPU=
PYTORCH_INDEX_URL_CUDA=
