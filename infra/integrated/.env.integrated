# =============================================================================
# VOYANT INTEGRATED MODE - SomaAgentHub Connection
# =============================================================================
# This file connects Voyant to SomaAgentHub's shared infrastructure.
# SomaAgentHub must be running first.
# =============================================================================

VOYANT_DEPLOYMENT_MODE=integrated

# -----------------------------------------------------------------------------
# SomaAgentHub Service URLs
# -----------------------------------------------------------------------------
SOMA_POLICY_URL=http://policy-engine:10020
SOMA_MEMORY_URL=http://memory-gateway:8000
SOMA_ORCHESTRATOR_URL=http://orchestrator:10001
SOMA_IDENTITY_URL=http://identity-service:10002
SOMA_GATEWAY_URL=http://gateway-api:10000

# -----------------------------------------------------------------------------
# Shared Infrastructure (from SomaAgentHub)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://soma:soma@postgres:5432/voyant
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TEMPORAL_HOST=temporal:7233

# -----------------------------------------------------------------------------
# MinIO (Shared or Voyant-specific)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=voyant
MINIO_SECRET_KEY=voyant123

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
SOMA_NETWORK=somastack-net

# -----------------------------------------------------------------------------
# Ports (Internal to Hub Cluster)
# -----------------------------------------------------------------------------
VOYANT_API_PORT=8080
VOYANT_MCP_PORT=8081
