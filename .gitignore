# ============================================================================
# Django / Python Project Ignore Rules
# ============================================================================

# Bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.cache/
.hypothesis/

# Coverage and test outputs
.coverage
.coverage.*
htmlcov/
coverage.xml

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Environment files (keep templates)
.env
.env.*
!.env.example
!**/.env.example
!**/.env.production.example
!infra/integrated/.env.integrated

# Build and packaging artifacts
build/
dist/
downloads/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
voyant_udb.egg-info/
.installed.cfg
*.egg
*.whl

# Native / extension artifacts
*.so
*.dylib

# Django/runtime local files
*.log
logs/
*.pid
*.sqlite
*.sqlite3
*.db
*.duckdb
*.duckdb*
staticfiles/
media/

# Data and local generated artifacts
data/
artifacts/
uploads/
tmp/
temp/
*.tmp
*.bak
*.parquet
*.csv.gz
*.json.gz

# Notebook and exploratory files
.ipynb_checkpoints/
*.ipynb

# Tooling
.tox/
.nox/
Pipfile.lock
poetry.lock

# Frontend
node_modules/
dashboard/node_modules/

# IDE/editor and OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Infrastructure and secrets
*.pem
*.key
*.crt
secrets/
.secrets/
*.kubeconfig
.terraform/
*.tfstate
*.tfstate.backup

# Docker local override
docker-compose.override.yml

# Local override configs
config_overrides.yaml
.local/
