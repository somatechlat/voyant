# =============================================================================
# VOYANT PRODUCTION ENVIRONMENT
# =============================================================================
# COPY THIS TO .env.production AND FILL IN SECRETS
# DO NOT COMMIT .env.production TO VERSION CONTROL
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
VOYANT_ENV=production
DEBUG=false
ALLOWED_HOSTS=voyant.example.com
CSRF_TRUSTED_ORIGINS=https://voyant.example.com

# -----------------------------------------------------------------------------
# Django Secrets (REQUIRED - Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))")
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=<GENERATE-SECURE-KEY>

# -----------------------------------------------------------------------------
# PostgreSQL (REQUIRED)
# -----------------------------------------------------------------------------
POSTGRES_USER=voyant
POSTGRES_PASSWORD=<SECURE-PASSWORD>

# -----------------------------------------------------------------------------
# Redis (REQUIRED)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=<SECURE-PASSWORD>

# -----------------------------------------------------------------------------
# MinIO / S3 (REQUIRED)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=voyant-admin
MINIO_ROOT_PASSWORD=<SECURE-PASSWORD-MIN-32-CHARS>

# -----------------------------------------------------------------------------
# Keycloak (REQUIRED)
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<SECURE-PASSWORD>
KEYCLOAK_CLIENT_SECRET=<CLIENT-SECRET>
KEYCLOAK_HOSTNAME=auth.voyant.example.com

# -----------------------------------------------------------------------------
# Lago Billing (Optional)
# -----------------------------------------------------------------------------
LAGO_API_KEY=<LAGO-API-KEY>
LAGO_SECRET_KEY=<MIN-32-CHARS-SECRET-KEY>
LAGO_ENCRYPTION_KEY=<MIN-32-CHARS-ENCRYPTION-KEY>

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
VOYANT_ENABLE_QUALITY=true
VOYANT_ENABLE_BILLING=true
VOYANT_ENABLE_DATAHUB=true

# -----------------------------------------------------------------------------
# SomaAgentHub Integration (Optional - for Integrated Mode)
# -----------------------------------------------------------------------------
# VOYANT_DEPLOYMENT_MODE=integrated
# SOMA_POLICY_URL=http://policy-engine:10020
# SOMA_MEMORY_URL=http://memory-gateway:8000
# SOMA_ORCHESTRATOR_URL=http://orchestrator:10001
